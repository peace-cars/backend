generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model districts {
  id                                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                    String      @unique
  region                                  String?
  created_at                              DateTime?   @default(now()) @db.Timestamptz(6)
  code                                    String?     @unique @db.VarChar(10)
  manager_id                              String?     @db.Uuid
  branches                                branches[]
  profiles_districts_manager_idToprofiles profiles?   @relation("districts_manager_idToprofiles", fields: [manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                               locations[]
  profiles                                profiles[]

  @@schema("public")
}

model branches {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  district_id       String?             @db.Uuid
  address           String?
  phone             String?
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  district          districts?          @relation(fields: [district_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles          profiles[]
  sourcing_requests sourcing_requests[]
  staff_shifts      staff_shifts[]
  trade_ins         trade_in_requests[]
  vehicles          vehicles[]

  @@unique([name, district_id])
  @@schema("public")
}

/// Legacy locations table (aliased from branches in some code paths)
model locations {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String              @db.VarChar(255)
  code              String?             @unique @db.VarChar(10)
  address           String?
  manager_id        String?             @db.Uuid
  phone_number      String?             @db.VarChar(20)
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  district_id       String?             @db.Uuid
  commissions       commissions[]
  custom_orders     custom_orders[]
  district          districts?          @relation(fields: [district_id], references: [id], onUpdate: NoAction)
  profiles          profiles[]
  staff_shifts      staff_shifts[]
  trade_in_requests trade_in_requests[]
  vehicles          vehicles[]

  @@index([district_id], map: "idx_locations_district_id")
  @@schema("public")
}

model roles {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String             @unique
  description String?
  created_at  DateTime?          @default(now()) @db.Timestamptz(6)
  profiles    profiles[]
  permissions role_permissions[]

  @@schema("public")
}

model permissions {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String             @unique
  slug        String             @unique
  description String?
  created_at  DateTime?          @default(now()) @db.Timestamptz(6)
  roles       role_permissions[]

  @@schema("public")
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
  @@schema("public")
}

model profiles {
  id                                                              String                        @id @db.Uuid
  role                                                            role_type?                    @default(USER)
  full_name                                                       String                        @db.VarChar(255)
  phone_number                                                    String?                       @unique @db.VarChar(20)
  location_id                                                     String?                       @db.Uuid
  commission_tier                                                 Decimal?                      @default(1.0) @db.Decimal(5, 2)
  avatar_url                                                      String?
  is_verified                                                     Boolean?                      @default(false)
  is_inspector_verified                                           Boolean?                      @default(false)
  gamification_points                                             Int?                          @default(0)
  created_at                                                      DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at                                                      DateTime?                     @default(now()) @db.Timestamptz(6)
  performance_rating                                              Decimal?                      @default(5.0) @db.Decimal(3, 2)
  total_completed_tasks                                           Int?                          @default(0)
  role_id                                                         String?                       @db.Uuid
  branch_id                                                       String?                       @db.Uuid
  district_id                                                     String?                       @db.Uuid
  date_of_birth                                                   DateTime?                     @db.Date
  telegram_chat_id                                                String?
  fcm_token                                                       String?
  fcm_meta                                                        Json?
  last_seen_at                                                    DateTime?                     @db.Timestamptz(6)
  bio                                                             String?
  username                                                        String?                       @unique @db.VarChar(50)
  approval_logs                                                   approval_logs[]
  audit_logs                                                      audit_logs[]
  commissions_commissions_approved_byToprofiles                   commissions[]                 @relation("commissions_approved_byToprofiles")
  commissions_commissions_beneficiary_idToprofiles                commissions[]                 @relation("commissions_beneficiary_idToprofiles")
  community_comments                                              community_comments[]
  community_events                                                community_events[]
  community_post_upvotes                                          community_post_upvotes[]
  community_posts                                                 community_posts[]
  conversations_conversations_assigned_staff_idToprofiles         conversations[]               @relation("conversations_assigned_staff_idToprofiles")
  conversations_conversations_customer_idToprofiles               conversations[]               @relation("conversations_customer_idToprofiles")
  crypto_audit_logs                                               crypto_audit_logs[]
  custom_orders                                                   custom_orders[]
  districts_districts_manager_idToprofiles                        districts[]                   @relation("districts_manager_idToprofiles")
  finance_plans                                                   finance_plans[]
  inspections                                                     inspections[]
  messages                                                        messages[]
  notifications                                                   notifications[]
  official_stamps                                                 official_stamps[]
  branch                                                          branches?                     @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  district                                                        districts?                    @relation(fields: [district_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                           users                         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  locations                                                       locations?                    @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roles                                                           roles?                        @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sourcing_requests_staff                                         sourcing_requests[]           @relation("sourcing_requests_assigned_staff_idToprofiles")
  sourcing_requests_customer                                      sourcing_requests[]           @relation("sourcing_requests_customer_idToprofiles")
  staff_budgets_staff_budgets_approver_idToprofiles               staff_budgets[]               @relation("staff_budgets_approver_idToprofiles")
  staff_budgets_staff_budgets_auditor_idToprofiles                staff_budgets[]               @relation("staff_budgets_auditor_idToprofiles")
  staff_budgets_staff_budgets_requester_idToprofiles              staff_budgets[]               @relation("staff_budgets_requester_idToprofiles")
  staff_reviews                                                   staff_reviews[]
  staff_shifts                                                    staff_shifts[]
  staff_tasks_staff_tasks_assigned_byToprofiles                   staff_tasks[]                 @relation("staff_tasks_assigned_byToprofiles")
  staff_tasks_staff_tasks_assigned_toToprofiles                   staff_tasks[]                 @relation("staff_tasks_assigned_toToprofiles")
  staff_unlocked_achievements                                     staff_unlocked_achievements[]
  system_logs                                                     system_logs[]
  system_settings                                                 system_settings[]
  trade_in_requests_trade_in_requests_assigned_staff_idToprofiles trade_in_requests[]           @relation("trade_in_requests_assigned_staff_idToprofiles")
  trade_in_requests_trade_in_requests_broker_idToprofiles         trade_in_requests[]           @relation("trade_in_requests_broker_idToprofiles")
  trade_in_requests_trade_in_requests_customer_idToprofiles       trade_in_requests[]           @relation("trade_in_requests_customer_idToprofiles")
  user_garages                                                    user_garages[]
  vehicle_expenses                                                vehicle_expenses[]
  vehicle_price_history                                           vehicle_price_history[]

  @@index([district_id], map: "idx_profiles_district_id")
  @@index([location_id], map: "idx_profiles_location_id")
  @@schema("public")
}

model community_posts {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String                    @db.Uuid
  title                   String                    @db.VarChar(255)
  content                 String
  upvotes                 Int                       @default(0)
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  images                  String[]                  @default([])
  youtube_url             String?
  post_type               String?                   @default("discussion") @db.VarChar(20)
  tags                    String[]                  @default([])
  updated_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  is_edited               Boolean?                  @default(false)
  community_comments      community_comments[]
  community_notifications community_notifications[]
  community_post_upvotes  community_post_upvotes[]
  profiles                profiles                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model vehicles {
  id                        String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vin_chassis               String                  @unique @db.VarChar(100)
  make                      String                  @db.VarChar(100)
  model                     String                  @db.VarChar(100)
  year                      Int
  fuel                      fuel_type
  duty                      duty_status
  battery_soh_percent       Decimal?                @db.Decimal(5, 2)
  charger                   charger_type?           @default(NONE)
  plate_code                String?                 @db.VarChar(50)
  software_language         String?                 @default("English") @db.VarChar(50)
  current_mileage           Int?
  purchase_cost_usd         Decimal?                @db.Decimal(12, 2)
  exchange_rate_at_purchase Decimal?                @db.Decimal(12, 2)
  shipping_customs_cost_etb Decimal?                @db.Decimal(12, 2)
  refurbishment_cost_etb    Decimal?                @default(0.00) @db.Decimal(12, 2)
  total_landed_cost_etb     Decimal?                @default(0.00) @db.Decimal(12, 2)
  retail_price_etb          Decimal                 @db.Decimal(12, 2)
  min_selling_price_etb     Decimal?                @db.Decimal(12, 2)
  status                    vehicle_status?         @default(SOURCING)
  location_id               String?                 @db.Uuid
  created_at                DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?               @default(now()) @db.Timestamptz(6)
  branch_id                 String?                 @db.Uuid
  images                    String[]                @default([])
  internal_documents        String[]                @default([])
  certified_km              Int?
  range_km                  Int?
  motor_power_kw            Int?
  drive_train               String?                 @default("RWD") @db.VarChar(20)
  interior_color            String?                 @db.VarChar(50)
  battery_capacity_kwh      Decimal?                @db.Decimal(10, 2)
  features                  String[]                @default([])
  unit_cost                 Decimal?                @default(0) @db.Decimal
  floor_plan_loan           Boolean?                @default(false)
  maturity_date             DateTime?               @db.Timestamptz(6)
  sold_date                 DateTime?               @db.Timestamptz(6)
  floor_plan_bank_id        String?                 @db.Uuid
  loan_reference_number     String?                 @db.VarChar(100)
  commissions               commissions[]
  conversations             conversations[]
  finance_plans             finance_plans[]
  inspections               inspections[]
  telegram_sessions         telegram_sessions[]
  vehicle_expenses          vehicle_expenses[]
  vehicle_price_history     vehicle_price_history[]
  branch                    branches?               @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bank_partners             bank_partners?          @relation(fields: [floor_plan_bank_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                 locations?              @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branch_id], map: "idx_vehicles_branch_id")
  @@index([created_at], map: "idx_vehicles_created_at")
  @@index([sold_date], map: "idx_vehicles_sold_date")
  @@index([status], map: "idx_vehicles_status")
  @@schema("public")
}

model trade_in_requests {
  id                                                     String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id                                            String?          @db.Uuid
  broker_id                                              String?          @db.Uuid
  assigned_staff_id                                      String?          @db.Uuid
  location_id                                            String?          @db.Uuid
  vehicle_make_model                                     String           @db.VarChar(255)
  car_description                                        String?
  user_asking_price_etb                                  Decimal?         @db.Decimal(12, 2)
  final_dealer_offer_etb                                 Decimal?         @db.Decimal(12, 2)
  staff_notes                                            String?
  dm_notes                                               String?
  gm_notes                                               String?
  status                                                 trade_in_status? @default(NEW_LEAD)
  created_at                                             DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at                                             DateTime?        @default(now()) @db.Timestamptz(6)
  photos                                                 Json?            @default("[]")
  financing_requested                                    Boolean?         @default(false)
  branch_id                                              String?          @db.Uuid
  vehicle_details                                        Json?            @default("{}")
  contact_phone                                          String?          @db.VarChar(20)
  contact_city                                           String?          @db.VarChar(100)
  approval_logs                                          approval_logs[]
  inspections                                            inspections[]
  staff_tasks                                            staff_tasks[]
  profiles_trade_in_requests_assigned_staff_idToprofiles profiles?        @relation("trade_in_requests_assigned_staff_idToprofiles", fields: [assigned_staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branch                                                 branches?        @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_trade_in_requests_broker_idToprofiles         profiles?        @relation("trade_in_requests_broker_idToprofiles", fields: [broker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_trade_in_requests_customer_idToprofiles       profiles?        @relation("trade_in_requests_customer_idToprofiles", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                                              locations?       @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([branch_id], map: "idx_trade_in_requests_branch_id")
  @@index([location_id], map: "idx_trade_in_requests_location_id")
  @@index([status], map: "idx_trade_in_requests_status")
  @@schema("public")
}

model inspections {
  id                   String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trade_in_id          String?            @db.Uuid
  inspector_id         String             @db.Uuid
  mechanical_score     Int?
  exterior_score       Int?
  interior_score       Int?
  battery_health_score Int?
  is_certified         Boolean?           @default(false)
  pdf_report_url       String?
  libre_photo_url      String?
  created_at           DateTime?          @default(now()) @db.Timestamptz(6)
  checklist            Json?              @default("{}")
  detailed_photos      Json?              @default("[]")
  ev_data              Json?              @default("{}")
  final_notes          String?
  vehicle_id           String?            @db.Uuid
  profiles             profiles           @relation(fields: [inspector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trade_in_requests    trade_in_requests? @relation(fields: [trade_in_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vehicles             vehicles?          @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)

  @@index([vehicle_id], map: "idx_inspections_vehicle")
  @@schema("public")
}

model staff_shifts {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staff_id       String?    @db.Uuid
  clocked_in_at  DateTime?  @default(now()) @db.Timestamptz(6)
  clocked_out_at DateTime?  @db.Timestamptz(6)
  location_id    String?    @db.Uuid
  is_active      Boolean?   @default(true)
  branch_id      String?    @db.Uuid
  branch         branches?  @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations      locations? @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles       profiles?  @relation(fields: [staff_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model conversations {
  id                                                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                                        String?    @db.Uuid
  vehicle_id                                         String?    @db.Uuid
  last_message                                       String?
  created_at                                         DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                                         DateTime?  @default(now()) @db.Timestamptz(6)
  telegram_chat_id                                   String?
  customer_name                                      String?
  source                                             String?    @default("WEB")
  assigned_staff_id                                  String?    @db.Uuid
  status                                             String?    @default("OPEN") @db.VarChar(20)
  profiles_conversations_assigned_staff_idToprofiles profiles?  @relation("conversations_assigned_staff_idToprofiles", fields: [assigned_staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  profiles_conversations_customer_idToprofiles       profiles?  @relation("conversations_customer_idToprofiles", fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vehicles                                           vehicles?  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  messages                                           messages[]

  @@unique([telegram_chat_id, vehicle_id], map: "idx_conv_telegram_vehicle", where: raw("(telegram_chat_id IS NOT NULL)"))
  @@index([assigned_staff_id], map: "idx_conversations_assigned_staff")
  @@index([status], map: "idx_conversations_status")
  @@index([telegram_chat_id], map: "idx_conversations_telegram_chat")
  @@schema("public")
}

