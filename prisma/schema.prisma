generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Organizational Infrastructure
// ==========================================

model districts {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @db.VarChar(255)
  region      String?
  code        String?    @unique @db.VarChar(10)
  manager_id  String?    @db.Uuid
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  branches    branches[]
  locations   locations[]
  profiles    profiles[]
}

model branches {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @db.VarChar(255)
  district_id String?    @db.Uuid
  address     String?
  phone       String?    @db.VarChar(20)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  district    districts? @relation(fields: [district_id], references: [id], onDelete: Cascade)
  profiles    profiles[]
  vehicles    vehicles[]
  trade_ins   trade_in_requests[]
  staff_shifts staff_shifts[]
}

/// Legacy locations table (aliased from branches in some code paths)
model locations {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @db.VarChar(255)
  code        String?    @unique @db.VarChar(10)
  address     String?
  manager_id  String?    @db.Uuid
  phone_number String?   @db.VarChar(20)
  is_active   Boolean?   @default(true)
  district_id String?    @db.Uuid
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  district    districts? @relation(fields: [district_id], references: [id])
}

// ==========================================
// RBAC System
// ==========================================

model roles {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @unique @db.VarChar(50)
  description String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  permissions role_permissions[]
  profiles    profiles[]
}

model permissions {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String?
  slug        String     @unique @db.VarChar(100)
  description String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)

  roles       role_permissions[]
}

model role_permissions {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid

  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

model profiles {
  id                    String     @id @db.Uuid
  role                  String?    @db.VarChar(50)
  role_id               String?    @db.Uuid
  full_name             String     @db.VarChar(255)
  phone_number          String?    @unique @db.VarChar(20)

  // Scoping Hierarchy
  branch_id             String?    @db.Uuid
  district_id           String?    @db.Uuid

  commission_tier       Decimal?   @default(1.0) @db.Decimal(5, 2)
  avatar_url            String?
  is_verified           Boolean?   @default(false)
  is_inspector_verified Boolean?   @default(false)
  gamification_points   Int?       @default(0)
  performance_rating    Decimal?   @default(5.0) @db.Decimal(3, 2)
  total_completed_tasks Int?       @default(0)
  date_of_birth         DateTime?  @db.Date
  telegram_chat_id      String?
  fcm_token             String?
  fcm_meta              Json?
  last_seen_at          DateTime?  @db.Timestamptz(6)
  created_at            DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?  @default(now()) @db.Timestamptz(6)

  // Relations
  roles                 roles?     @relation(fields: [role_id], references: [id])
  branch                branches?  @relation(fields: [branch_id], references: [id])
  district              districts? @relation(fields: [district_id], references: [id])
}

// ==========================================
// Core Entities
// ==========================================

model vehicles {
  id                         String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vin_chassis                String     @unique @db.VarChar(100)
  make                       String     @db.VarChar(100)
  model                      String     @db.VarChar(100)
  year                       Int
  fuel                       String     @db.VarChar(50)
  duty                       String     @db.VarChar(50)
  battery_soh_percent        Decimal?   @db.Decimal(5, 2)
  charger                    String?    @default("NONE") @db.VarChar(50)
  plate_code                 String?    @db.VarChar(50)
  software_language          String?    @default("English") @db.VarChar(50)
  current_mileage            Int?
  purchase_cost_usd          Decimal?   @db.Decimal(12, 2)
  exchange_rate_at_purchase  Decimal?   @db.Decimal(12, 2)
  shipping_customs_cost_etb  Decimal?   @db.Decimal(12, 2)
  refurbishment_cost_etb     Decimal?   @default(0.00) @db.Decimal(12, 2)
  total_landed_cost_etb      Decimal?   @default(0.00) @db.Decimal(12, 2)
  retail_price_etb           Decimal    @db.Decimal(12, 2)
  min_selling_price_etb      Decimal?   @db.Decimal(12, 2)
  status                     String?    @default("SOURCING") @db.VarChar(50)
  branch_id                  String?    @db.Uuid
  images                     String[]
  certified_km               Int?
  range_km                   Int?
  motor_power_kw             Int?
  drive_train                String?
  interior_color             String?
  battery_capacity_kwh       Decimal?   @db.Decimal(10, 2)
  features                   String[]
  unit_cost                  Decimal?   @db.Decimal(12, 2)
  floor_plan_loan            Decimal?   @db.Decimal(12, 2)
  maturity_date              DateTime?  @db.Date
  sold_date                  DateTime?  @db.Date
  floor_plan_bank_id         String?    @db.Uuid
  loan_reference_number      String?
  created_at                 DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?  @default(now()) @db.Timestamptz(6)

  branch                     branches?  @relation(fields: [branch_id], references: [id])
}

model trade_in_requests {
  id                    String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id           String?    @db.Uuid
  broker_id             String?    @db.Uuid
  assigned_staff_id     String?    @db.Uuid
  branch_id             String?    @db.Uuid
  vehicle_make_model    String     @db.VarChar(255)
  car_description       String?
  user_asking_price_etb Decimal?   @db.Decimal(12, 2)
  final_dealer_offer_etb Decimal?  @db.Decimal(12, 2)
  staff_notes           String?
  dm_notes              String?
  gm_notes              String?
  status                String?    @default("NEW_LEAD") @db.VarChar(50)
  photos                String[]
  financing_requested   Boolean?   @default(false)
  vehicle_details       Json?
  contact_phone         String?
  contact_city          String?
  created_at            DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?  @default(now()) @db.Timestamptz(6)

  branch                branches?  @relation(fields: [branch_id], references: [id])
}

model inspections {
  id                   String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trade_in_id          String?    @db.Uuid
  inspector_id         String     @db.Uuid
  mechanical_score     Int?
  exterior_score       Int?
  interior_score       Int?
  battery_health_score Int?
  is_certified         Boolean?   @default(false)
  pdf_report_url       String?
  libre_photo_url      String?
  checklist            Json?
  detailed_photos      Json?
  ev_data              Json?
  final_notes          String?
  vehicle_id           String?    @db.Uuid
  created_at           DateTime?  @default(now()) @db.Timestamptz(6)
}

model staff_shifts {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  staff_id       String?    @db.Uuid
  branch_id      String?    @db.Uuid
  clocked_in_at  DateTime?  @default(now()) @db.Timestamptz(6)
  clocked_out_at DateTime?  @db.Timestamptz(6)
  is_active      Boolean?   @default(true)

  branch         branches?  @relation(fields: [branch_id], references: [id])
}

model conversations {
  id                String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id       String?    @db.Uuid
  vehicle_id        String?    @db.Uuid
  last_message      String?
  telegram_chat_id  String?
  customer_name     String?
  source            String?
  assigned_staff_id String?    @db.Uuid
  status            String?
  created_at        DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?  @default(now()) @db.Timestamptz(6)
}
