  reauthentication_sent_at                                        DateTime?                 @db.Timestamptz(6)
  is_sso_user                                                     Boolean                   @default(false)
  deleted_at                                                      DateTime?                 @db.Timestamptz(6)
  is_anonymous                                                    Boolean                   @default(false)
  identities                                                      identities[]
  mfa_factors                                                     mfa_factors[]
  oauth_authorizations                                            oauth_authorizations[]
  oauth_consents                                                  oauth_consents[]
  one_time_tokens                                                 one_time_tokens[]
  sessions                                                        sessions[]
  webauthn_challenges                                             webauthn_challenges[]
  webauthn_credentials                                            webauthn_credentials[]
  community_event_rsvps                                           community_event_rsvps[]
  community_follows_community_follows_follower_idTousers          community_follows[]       @relation("community_follows_follower_idTousers")
  community_follows_community_follows_following_idTousers         community_follows[]       @relation("community_follows_following_idTousers")
  community_notifications_community_notifications_actor_idTousers community_notifications[] @relation("community_notifications_actor_idTousers")
  community_notifications_community_notifications_user_idTousers  community_notifications[] @relation("community_notifications_user_idTousers")
  profiles                                                        profiles?

  @@index([instance_id])
